# ======================================= #
#  ENVIRONMENT VARIABLES FOR EMERALD API  #
# ======================================= #
#
# How to use:
#   1. Copy this file to .env
#   2. Fill in the values for each variable
#
# ```bash
# cp .env.template .env
# ```

# -------- DATABASE (PostgreSQL) -------- #

# Login username of the database
DB_USERNAME=postgres

# Login password of the database
DB_PASSWORD=

# Name of the database
DB_NAME=postgres

# JDBC URL of the database
#
# INFO: For local development use 'localhost', docker-compose uses service name 'postgres' as host.
JDBC_URL=jdbc:postgresql://localhost:5432/postgres

# ---------------- REDIS ---------------- #

# Redis server host
#
# INFO: For local development use 'localhost', docker-compose uses service name 'redis' as host.
REDIS_HOST=localhost

# Redis server port
REDIS_PORT=6379

# Login username of the redis server.
#
# INFO: By default, Redis does not require a username. If you want to use a username, you can set it here.
REDIS_USERNAME=default

# Login password of the redis server
#
# INFO: By default, Redis does not require a password. If you want to use a password, you can set it here.
REDIS_PASSWORD=

# ----------------- JWT ----------------- #

# Secret key for signing JWT tokens (algorithm: HS256)
#
# IMPORTANT: This key must be long and random. Do not use a simple or guessable key.
#
# You can generate a secure key using the following command:
# ```bash
# openssl rand -base64 64
# ```
JWT_SECRET=

# Expiration time for access tokens in milliseconds (15 minutes)
JWT_ACCESS_EXPIRATION=900000

# Expiration time for refresh tokens in milliseconds (7 days)
JWT_REFRESH_EXPIRATION=604800000
